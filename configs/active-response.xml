<!-- Active Response Configuration -->
<!-- Add these inside the <ossec_config> block in /var/ossec/etc/ossec.conf -->
 
<!-- Define the firewall-drop command -->
<command>
  <name>firewall-drop</name>
  <executable>firewall-drop</executable>
  <timeout_allowed>yes</timeout_allowed>
</command>
 
<!-- Active response: block attacker IP for 180 seconds -->
<!-- Executes on the local agent that detected the attack -->
<active-response>
  <command>firewall-drop</command>
  <location>local</location>
  <rules_id>100003</rules_id>
  <timeout>180</timeout>
</active-response>
 
